xml
@model POC.VisitTracker.Models.Visit

<div>
    @using (Html.BeginForm("Edit", "Visit", FormMethod.Post, new { id = "editVisitForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label for="PatientId" class="form-label">Patient ID</label>
            @Html.TextBoxFor(m => m.PatientId, new { @class = "form-control", placeholder = "e.g., P001" })
            @Html.ValidationMessageFor(m => m.PatientId, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            <label for="VisitDate" class="form-label">Visit Date</label>
            @Html.TextBoxFor(m => m.VisitDate, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
            @Html.ValidationMessageFor(m => m.VisitDate, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            <label for="VisitType" class="form-label">Visit Type</label>
            @Html.DropDownListFor(m => m.VisitType, new SelectList(new[] { "OPD", "IP", "ER" }), "-- Select --", new { @class = "form-select" })
        </div>

        <div class="mb-3">
            <label for="Status" class="form-label">Status</label>
            @Html.DropDownListFor(m => m.Status, new SelectList(new[] { "New", "Pending", "Submitted", "Closed" }), "-- Select --", new { @class = "form-select" })
        </div>

        <div class="mb-3">
            <label for="Notes" class="form-label">Notes</label>
            @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", rows = 4, placeholder = "Additional notes..." })
        </div>

        @Html.HiddenFor(m => m.Id)

        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Visit</button>
        </div>
    }
</div>
